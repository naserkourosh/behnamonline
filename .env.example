# ─────────────────────────────────────────────
#  بهنام (Behnam) — Environment configuration
#  Copy this file to ".env" and adjust values.
# ─────────────────────────────────────────────

APP_NAME="بهنام"
APP_ENV=local            # local | production
APP_DEBUG=true           # true on dev, false in production
APP_URL=http://behnam.test
APP_KEY=                 # 32+ random chars; used for signing cookies/tokens

# Database (WampServer MySQL 8 defaults: user root, empty password)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=behnam
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Sessions / security
SESSION_LIFETIME=31536000   # seconds (1 year) — cookie + server GC
SECURE_COOKIES=false     # set true behind HTTPS in production

# SMS (Melipayamak) — "mock" just logs to storage/logs/sms.log.
# PRODUCTION: set SMS_DRIVER=melipayamak. The REST API
# (github.com/Melipayamak/melipayamak-php) authenticates with the PANEL
# username/password — no API key needed.
#   MELIPAYAMAK_USERNAME/PASSWORD → your melipayamak.com panel login
#   MELIPAYAMAK_FROM              → sender line number (شماره خط) from the
#                                   panel's "خطوط من" page, e.g. 50004001...
#   MELIPAYAMAK_OTP_BODY_ID       → (recommended) approved pattern code
#                                   (کد متن خدماتی) — OTP goes via the shared
#                                   SERVICE line and reaches numbers that
#                                   blocked promotional SMS.
SMS_DRIVER=mock          # mock | melipayamak
MELIPAYAMAK_USERNAME=
MELIPAYAMAK_PASSWORD=
MELIPAYAMAK_FROM=
MELIPAYAMAK_OTP_BODY_ID=

# Payment (used from Phase 3) — "mock" simulates a successful gateway.
# For Zarinpal sandbox testing use merchant 564c79ee-4fdf-462d-9d92-adeadaaed37c
# and ZARINPAL_SANDBOX=true. Switch to your real merchant id + ZARINPAL_SANDBOX=false
# for production.
PAYMENT_DRIVER=mock      # mock | zarinpal
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=true
